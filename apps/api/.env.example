NODE_ENV=development
PORT=3001

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# 서버 전용. Supabase secret key 또는 legacy service_role key. 브라우저/문서/Git에 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVER_ONLY_SUPABASE_KEY
# PLAN 호환용 예약 변수. 현재 API 코드에서는 직접 사용하지 않음.
SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_OR_ANON_KEY

# Toss Payments
TOSS_SECRET_KEY=YOUR_TOSS_SECRET_KEY

# Resend
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=YOUR_VERIFIED_SENDER_EMAIL

# 전화번호 암호화 키 (32바이트 hex)
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PHONE_ENCRYPT_KEY=YOUR_64_CHARACTER_HEX_KEY

# Web Push (VAPID)
# 생성: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY

# URL
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
